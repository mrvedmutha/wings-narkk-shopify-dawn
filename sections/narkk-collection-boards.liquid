{{ 'narkk-plp-category-grid.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} .narkk-plp-category-grid {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

{%- comment -%}── Count every category so we can hide this step if empty ──{%- endcomment -%}
{%- assign board_count = 0 -%}
{%- for product in collection.products -%}
  {%- assign cat = product.metafields.custom.product_filter_category -%}
  {%- if cat == 'Boards' -%}
    {%- assign board_count = board_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- if board_count > 0 -%}

  {%- comment -%}── Ready Setups is unnumbered, so Boards is always step 1 ──{%- endcomment -%}
  {%- assign step_number = 1 -%}

  <section class="narkk-plp-category-grid" data-narkk-plp-category-grid>
    <div class="narkk-plp-category-grid__inner">

      {%- comment -%}── HEADER ──────────────────────────────────────────────{%- endcomment -%}
      <div class="narkk-plp-category-grid__header">
        <ol class="narkk-plp-category-grid__heading-list" start="{{ step_number }}">
          <li class="narkk-plp-category-grid__heading">{{- section.settings.heading -}}</li>
        </ol>
        {%- if section.settings.description != blank -%}
          <p class="narkk-plp-category-grid__desc">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>

      {%- comment -%}── BOARDS GRID ─────────────────────────────────────────{%- endcomment -%}
      {%- paginate collection.products by 50 -%}
        <div class="narkk-plp-category-grid__grid">
          {%- for product in collection.products -%}
            {%- if product.metafields.custom.product_filter_category == 'Boards' -%}
              {%- render 'narkk-card-board', product: product -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endpaginate -%}

    </div>
  </section>

{%- endif -%}

{% schema %}
{
  "name": "Collection Boards",
  "tag": "section",
  "class": "narkk-plp-category-grid-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Renders products where custom.product_filter_category = Boards, in manual collection sort order. Hides itself if no boards are uploaded. Ready Setups is unnumbered, so this is always step 1; the step number shifts automatically if Accessories has products but Boards doesn't."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Start with Board"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Choose your base. Build from Solid Birch Plywood"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Collection Boards"
    }
  ]
}
{% endschema %}
