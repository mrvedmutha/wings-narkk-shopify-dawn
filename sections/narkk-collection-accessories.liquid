{{ 'narkk-plp-category-grid.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} .narkk-plp-category-grid {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

{%- assign per_page = section.settings.per_page -%}

<section class="narkk-plp-category-grid" data-narkk-plp-category-grid>
  <div class="narkk-plp-category-grid__inner">

    {%- comment -%}── HEADER ────────────────────────────────────────────────{%- endcomment -%}
    <div class="narkk-plp-category-grid__header">
      <ol class="narkk-plp-category-grid__heading-list" start="{{ section.settings.step_number }}">
        <li class="narkk-plp-category-grid__heading">{{- section.settings.heading -}}</li>
      </ol>
      {%- if section.settings.description != blank -%}
        <p class="narkk-plp-category-grid__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- paginate collection.products by 50 -%}

      {%- comment -%}── Count accessories (first pass) ────────────────────────{%- endcomment -%}
      {%- assign acc_total = 0 -%}
      {%- for product in collection.products -%}
        {%- assign cat = product.metafields.custom.product_filter_category -%}
        {%- if cat == 'Accessories' or cat == 'Wall mount kits' -%}
          {%- assign acc_total = acc_total | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%}── ACCESSORIES GRID (second pass) ────────────────────────{%- endcomment -%}
      <div
        class="narkk-plp-category-grid__grid"
        data-grid
        data-per-page="{{ per_page }}"
        data-total="{{ acc_total }}"
      >
        {%- assign acc_index = 0 -%}
        {%- for product in collection.products -%}
          {%- assign cat = product.metafields.custom.product_filter_category -%}
          {%- if cat == 'Accessories' or cat == 'Wall mount kits' -%}
            {%- render 'narkk-card-accessory', product: product, index: acc_index, per_page: per_page -%}
            {%- assign acc_index = acc_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if acc_total > per_page -%}
        {%- assign remaining = acc_total | minus: per_page -%}
        <div class="narkk-plp-category-grid__load-more" data-load-more-wrap>
          <button
            class="button narkk-btn-outlined narkk-btn--plus narkk-plp-category-grid__load-more-btn"
            data-load-more
            data-remaining="{{ remaining }}"
          >
            <span class="narkk-btn__plus">+</span>
            <span class="narkk-btn__label" data-load-more-label>Load More ({{ remaining }})</span>
          </button>
        </div>
      {%- endif -%}

    {%- endpaginate -%}

  </div>
</section>

<script src="{{ 'narkk-plp-category-grid.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Collection Accessories",
  "tag": "section",
  "class": "narkk-plp-category-grid-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Renders products where custom.product_filter_category = Accessories or Wall mount kits, in manual collection sort order."
    },
    {
      "type": "range",
      "id": "step_number",
      "label": "Step number",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Add Accessories"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Pick what you need to build your setup. Up to 9 accessories with standard board"
    },
    {
      "type": "range",
      "id": "per_page",
      "label": "Products per page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 8
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Collection Accessories"
    }
  ]
}
{% endschema %}
