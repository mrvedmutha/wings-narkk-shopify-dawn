{%- comment -%}
  Section: narkk-trade-apply-modal
  A Trade Program application modal. You can add several instances of this
  section (to the same template or different ones) — each gets its own
  Shopify Forms app block and its own "Modal handle".

  Any button elsewhere on the site with a matching
  data-trade-modal-open="<handle>" attribute opens this specific instance.
  Give each instance a unique handle if you need more than one form; leave
  the default handle on both the modal and its trigger button if you only
  need one.
{%- endcomment -%}

{{ 'narkk-trade-apply-modal.css' | asset_url | stylesheet_tag }}

{%- assign modal_handle = section.settings.modal_handle | default: 'trade-application' | handleize -%}

{%- comment -%}── Overlay ───────────────────────────────────────────{%- endcomment -%}
<div
  class="narkk-tam__overlay"
  data-tam-overlay
  data-modal-handle="{{ modal_handle }}"
  aria-hidden="true"
>&nbsp;</div>

{%- comment -%}── Modal ─────────────────────────────────────────────{%- endcomment -%}
<div
  class="narkk-tam"
  data-tam-modal
  data-modal-handle="{{ modal_handle }}"
  role="dialog"
  aria-modal="true"
  aria-label="{{ section.settings.heading }}"
  aria-hidden="true"
>
  <div class="narkk-tam__panel" data-lenis-prevent>

    {%- comment -%}── Close button ──────────────────────────────────{%- endcomment -%}
    <button class="narkk-tam__close" type="button" data-tam-close aria-label="{{ 'accessibility.close' | t }}">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M4 4L20 20M20 4L4 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    {%- comment -%}── Left panel — pitch copy (no scroll) ───────────{%- endcomment -%}
    <div class="narkk-tam__left">
      <p class="narkk-tam__eyebrow">{{ section.settings.eyebrow }}</p>
      <div class="narkk-tam__left-text">
        <p class="narkk-tam__heading">{{ section.settings.heading }}</p>
        <p class="narkk-tam__desc">{{ section.settings.description }}</p>
      </div>
    </div>

    {%- comment -%}── Right panel — scrollable Forms app block ──────{%- endcomment -%}
    <div class="narkk-tam__right">
      {%- content_for 'blocks' -%}
      {%- if section.blocks.size == 0 and request.design_mode -%}
        <p class="narkk-tam__app-placeholder">
          Add a block here — Apps &gt; Forms — then paste the Form ID from your Shopify Forms app into the block's settings.
        </p>
      {%- endif -%}
    </div>

  </div>
</div>

<script src="{{ 'narkk-trade-apply-modal.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Trade Apply Modal",
  "tag": "section",
  "class": "narkk-tam-section",
  "settings": [
    {
      "type": "text",
      "id": "modal_handle",
      "label": "Modal handle",
      "info": "A short unique ID, e.g. trade-application. CTA buttons/blocks reference this exact value in their own \"Modal handle\" setting to open this specific modal — give each modal instance a different handle if you're using more than one form on the site.",
      "default": "trade-application"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Apply for trade program"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Narkk Trade Program"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We partner with designers who specify with intention. Tell us about your work, and we'll get back to you with the next steps."
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Trade Apply Modal"
    }
  ]
}
{% endschema %}
