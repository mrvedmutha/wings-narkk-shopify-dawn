{{ 'narkk-plp-category-grid.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} .narkk-plp-category-grid {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<section class="narkk-plp-category-grid" data-narkk-plp-category-grid>
  <div class="narkk-plp-category-grid__inner">

    {%- comment -%}── HEADER ────────────────────────────────────────────────{%- endcomment -%}
    <div class="narkk-plp-category-grid__header">
      <ol class="narkk-plp-category-grid__heading-list" start="{{ section.settings.step_number }}">
        <li class="narkk-plp-category-grid__heading">
          {{- section.settings.heading -}}
        </li>
      </ol>
      {%- if section.settings.description != blank -%}
        <p class="narkk-plp-category-grid__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- comment -%}── PRODUCT GRID ──────────────────────────────────────────{%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      {%- assign per_page = section.settings.per_page -%}
      <div class="narkk-plp-category-grid__grid" data-grid data-per-page="{{ per_page }}" data-total="{{ section.blocks.size }}">
        {%- for block in section.blocks -%}
          <article class="narkk-plp-card{% if forloop.index0 >= per_page %} narkk-plp-card--hidden{% endif %}" data-card-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            <a href="{%- if block.settings.url != blank -%}{{ block.settings.url }}{%- else -%}#{%- endif -%}" class="narkk-plp-card__link">

              {%- comment -%} Image area {%- endcomment -%}
              <div class="narkk-plp-card__image-wrap">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    srcset="
                      {{ block.settings.image | image_url: width: 400 }} 400w,
                      {{ block.settings.image | image_url: width: 600 }} 600w,
                      {{ block.settings.image | image_url: width: 800 }} 800w
                    "
                    sizes="(max-width: 390px) 100vw, (max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
                    alt="{{ block.settings.title | escape }}"
                    loading="lazy"
                    class="narkk-plp-card__image"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'narkk-plp-card__image narkk-plp-card__image--placeholder' }}
                {%- endif -%}
                {%- if block.settings.badge != blank -%}
                  <span class="narkk-plp-card__badge">{{- block.settings.badge -}}</span>
                {%- endif -%}
              </div>

              {%- comment -%} Card info {%- endcomment -%}
              <div class="narkk-plp-card__info">
                <div class="narkk-plp-card__meta">
                  <h3 class="narkk-plp-card__name">{{ block.settings.title }}</h3>
                  {%- if block.settings.sub_info != blank -%}
                    <p class="narkk-plp-card__sub-info">{{ block.settings.sub_info }}</p>
                  {%- endif -%}
                </div>
                {%- if block.settings.price != blank -%}
                  <p class="narkk-plp-card__price">{{ block.settings.price }}</p>
                {%- endif -%}
              </div>

            </a>
          </article>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > per_page -%}
        {%- assign remaining = section.blocks.size | minus: per_page -%}
        <div class="narkk-plp-category-grid__load-more" data-load-more-wrap>
          <button
            class="button narkk-btn-outlined narkk-btn--plus narkk-plp-category-grid__load-more-btn"
            data-load-more
            data-remaining="{{ remaining }}"
          >
            <span class="narkk-btn__plus">+</span>
            <span class="narkk-btn__label" data-load-more-label>Load More ({{ remaining }})</span>
          </button>
        </div>
      {%- endif -%}
    {%- endif -%}

  </div>
</section>

<script src="{{ 'narkk-plp-category-grid.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "PLP Category Grid",
  "tag": "section",
  "class": "narkk-plp-category-grid-section",
  "max_blocks": 24,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "range",
      "id": "step_number",
      "label": "Step number",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 1
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Category heading",
      "default": "Start with Board"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Choose your base. Build from Solid Birch Plywood"
    },
    {
      "type": "range",
      "id": "per_page",
      "label": "Products per page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 8
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "info": "Optional size label e.g. TINY, SMALL, STANDARD, LARGE"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product name",
          "default": "Product Name"
        },
        {
          "type": "text",
          "id": "sub_info",
          "label": "Dimensions / pack info",
          "info": "Optional — e.g. 550 x 150 x 16 mm or (Pack of 6s)"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "Rs. 0.00"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PLP Category Grid"
    }
  ]
}
{% endschema %}
