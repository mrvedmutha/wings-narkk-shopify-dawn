{{ 'narkk-plp-big-grid.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} .narkk-plp-big-grid {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

{%- comment -%}── Count every category so we can hide empty steps and renumber the rest ──{%- endcomment -%}
{%- assign bundle_count = 0 -%}
{%- assign board_count = 0 -%}
{%- assign acc_count = 0 -%}
{%- for product in collection.products -%}
  {%- assign cat = product.metafields.custom.product_filter_category -%}
  {%- if cat == 'Bundles' -%}
    {%- assign bundle_count = bundle_count | plus: 1 -%}
  {%- elsif cat == 'Boards' -%}
    {%- assign board_count = board_count | plus: 1 -%}
  {%- elsif cat == 'Accessories' or cat == 'Wall mount kits' -%}
    {%- assign acc_count = acc_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- if bundle_count == 0 and board_count == 0 and acc_count == 0 -%}

  {%- comment -%}── Whole collection is empty ─────────────────────────────{%- endcomment -%}
  <section class="narkk-plp-big-grid" data-narkk-plp-big-grid>
    <div class="narkk-plp-big-grid__inner">
      <div class="narkk-plp-big-grid__empty-state">
        <p class="narkk-plp-big-grid__empty-state-text">This collection is empty right now. Check back soon.</p>
      </div>
    </div>
  </section>

{%- elsif bundle_count > 0 -%}

  {%- paginate collection.products by 50 -%}

    <section class="narkk-plp-big-grid" data-narkk-plp-big-grid>
      <div class="narkk-plp-big-grid__inner">

        {%- comment -%}── HEADER ────────────────────────────────────────────{%- endcomment -%}
        <div class="narkk-plp-big-grid__header">
          <div class="narkk-plp-big-grid__header-row">
            <h2 class="narkk-plp-big-grid__heading">{{- section.settings.heading -}}</h2>

            {%- if bundle_count > 2 -%}
              <div class="narkk-plp-big-grid__nav" aria-label="Slider controls">
                <button
                  class="narkk-plp-big-grid__nav-btn narkk-plp-big-grid__nav-btn--prev"
                  aria-label="Previous setup"
                  disabled
                >
                  <svg width="7" height="11" viewBox="0 0 7 11" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><path d="M6.46973 1.46973L1.96973 5.96973L6.46973 10.4697" stroke="currentColor" stroke-width="1.5"/></svg>
                </button>
                <button
                  class="narkk-plp-big-grid__nav-btn narkk-plp-big-grid__nav-btn--next"
                  aria-label="Next setup"
                >
                  <svg width="7" height="11" viewBox="0 0 7 11" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><path d="M0.530273 1.46973L5.03027 5.96973L0.530273 10.4697" stroke="currentColor" stroke-width="1.5"/></svg>
                </button>
              </div>
            {%- endif -%}
          </div>

          {%- if section.settings.description != blank -%}
            <p class="narkk-plp-big-grid__desc">{{ section.settings.description }}</p>
          {%- endif -%}
        </div>

        {%- comment -%}── SLIDER ────────────────────────────────────────────{%- endcomment -%}
        <div class="narkk-plp-big-grid__slider" data-slider data-total="{{ bundle_count }}">
          <div class="narkk-plp-big-grid__track" data-track>
            {%- for product in collection.products -%}
              {%- if product.metafields.custom.product_filter_category == 'Bundles' -%}
                {%- render 'narkk-card-bundle', product: product -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

      </div>
    </section>

  {%- endpaginate -%}

  <script src="{{ 'narkk-plp-big-grid.js' | asset_url }}" defer></script>

{%- endif -%}

{% schema %}
{
  "name": "Collection Ready Setups",
  "tag": "section",
  "class": "narkk-plp-big-grid-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Renders products where custom.product_filter_category = Bundles, in manual collection sort order. Hides itself if no bundles are uploaded. This step is unnumbered; the Boards and Accessories steps below number themselves automatically."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Ready Setups"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Curated combinations for every setup"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Collection Ready Setups"
    }
  ]
}
{% endschema %}
