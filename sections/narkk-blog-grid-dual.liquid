            {%- endfor -%}
          {%- endif -%}
        </div>

      </div>
    </div>

    {%- comment -%}── CTA LINKS ───────────────────────────────────────────{%- endcomment -%}
    {%- if section.settings.intentions_cta_label != blank -%}
      <div class="narkk-dual-grid__cta-wrap" data-narkk-panel-cta="intentions">
        <a
          href="{{ section.settings.intentions_cta_url | default: '#' }}"
          class="button narkk-btn-outlined narkk-btn--plus narkk-dual-grid__cta"
        >
          <span class="narkk-btn__plus">+</span>
          <span class="narkk-btn__label">{{ section.settings.intentions_cta_label }}</span>
        </a>
      </div>
    {%- endif -%}

    {%- if section.settings.narkk_cta_label != blank -%}
      <div class="narkk-dual-grid__cta-wrap narkk-dual-grid__cta-wrap--hidden" data-narkk-panel-cta="narkk">
        <a
          href="{{ section.settings.narkk_cta_url | default: '#' }}"
          class="button narkk-btn-outlined narkk-btn--plus narkk-dual-grid__cta"
        >
          <span class="narkk-btn__plus">+</span>
          <span class="narkk-btn__label">{{ section.settings.narkk_cta_label }}</span>
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<script src="{{ 'gsap.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'narkk-text-reveal.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'narkk-blog-grid-dual.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Blog Grid — Dual",
  "tag": "section",
  "class": "narkk-dual-grid-section",
  "settings": [
    {
      "type": "header",
      "content": "Intentions tab"
    },
    {
      "type": "text",
      "id": "intentions_heading",
      "label": "Tab label",
      "default": "Intentions"
    },
    {
      "type": "blog",
      "id": "intentions_blog",
      "label": "Blog source",
      "info": "Connect when ready — use blocks below until then"
    },
    {
      "type": "select",
      "id": "featured_position_intentions",
      "label": "Featured card position",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left",  "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "text",
      "id": "intentions_cta_label",
      "label": "CTA label",
      "default": "See all articles"
    },
    {
      "type": "url",
      "id": "intentions_cta_url",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Narkk tab"
    },
    {
      "type": "text",
      "id": "narkk_heading",
      "label": "Tab label",
      "default": "Narkk"
    },
    {
      "type": "blog",
      "id": "narkk_blog",
      "label": "Blog source",
      "info": "Connect when ready — use blocks below until then"
    },
    {
      "type": "select",
      "id": "featured_position_narkk",
      "label": "Featured card position",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left",  "label": "Left" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "narkk_cta_label",
      "label": "CTA label",
      "default": "See all articles"
    },
    {
      "type": "url",
      "id": "narkk_cta_url",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "intentions_card",
      "name": "Intentions — Article Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Article"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Article title"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "narkk_card",
      "name": "Narkk — Article Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Article"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Article title"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog Grid — Dual",
      "blocks": [
        { "type": "intentions_card", "settings": { "eyebrow": "Advice", "title": "Move beyond trends. Design a timeless sanctuary." } },
        { "type": "intentions_card", "settings": { "eyebrow": "Tips",   "title": "The art of intentional living starts here." } },
        { "type": "intentions_card", "settings": { "eyebrow": "Advice", "title": "Craft spaces that reflect who you truly are." } },
        { "type": "intentions_card", "settings": { "eyebrow": "Tips",   "title": "Simple changes, lasting impact on your home." } },
        { "type": "intentions_card", "settings": { "eyebrow": "Advice", "title": "Why quality always outlives the trend cycle." } },
        { "type": "intentions_card", "settings": { "eyebrow": "Advice", "title": "Building rituals around the objects you love." } },
        { "type": "intentions_card", "settings": { "eyebrow": "Tips",   "title": "A beginner's guide to curating with purpose." } },
        { "type": "narkk_card",      "settings": { "eyebrow": "Advice", "title": "Move beyond trends. Design a timeless sanctuary." } },
        { "type": "narkk_card",      "settings": { "eyebrow": "Tips",   "title": "The art of intentional living starts here." } },
        { "type": "narkk_card",      "settings": { "eyebrow": "Advice", "title": "Craft spaces that reflect who you truly are." } },
