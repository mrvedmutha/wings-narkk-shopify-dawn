{{ 'narkk-blog-grid-dual.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign i_label    = section.settings.intentions_heading | default: 'Intentions'
  assign n_label    = section.settings.narkk_heading      | default: 'Narkk'
  assign i_feat_pos = section.settings.featured_position_intentions | default: 'right'
  assign n_feat_pos = section.settings.featured_position_narkk      | default: 'left'

  assign i_blocks = section.blocks | where: 'type', 'intentions_card'
  assign n_blocks = section.blocks | where: 'type', 'narkk_card'

  assign i_use_blog = false
  if section.settings.intentions_blog != blank and section.settings.intentions_blog.articles_count > 0
    assign i_use_blog = true
  endif
  assign n_use_blog = false
  if section.settings.narkk_blog != blank and section.settings.narkk_blog.articles_count > 0
    assign n_use_blog = true
  endif
-%}

<section
  class="narkk-dual-grid"
  data-narkk-dual-grid
  data-i-label="{{ i_label | escape }}"
  data-n-label="{{ n_label | escape }}"
>
  <div class="narkk-dual-grid__inner">

    {%- comment -%}── HEADER ──────────────────────────────────────────────{%- endcomment -%}
    <div class="narkk-dual-grid__header">
      <h2 class="narkk-dual-grid__heading">
        Living with
        <span class="narkk-dual-grid__switch" data-narkk-switch>
          <span class="narkk-dual-grid__switch-label" data-narkk-switch-label>
            <span class="narkk-dual-grid__switch-text" data-narkk-switch-text>{{ i_label }}</span>
            <span class="narkk-dual-grid__switch-line" aria-hidden="true"></span>
          </span>
          <span class="narkk-dual-grid__switch-chevron" aria-hidden="true">
            <svg width="11" height="7" viewBox="0 0 11 7" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9.53027 0.530273L5.03027 5.03027L0.530273 0.530273" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </span>
          <ul class="narkk-dual-grid__dropdown" data-narkk-dropdown role="listbox" aria-label="Switch blog category">
            <li class="narkk-dual-grid__dropdown-item is-active" data-narkk-tab="intentions" role="option" tabindex="0">{{ i_label }}</li>
            <li class="narkk-dual-grid__dropdown-item" data-narkk-tab="narkk" role="option" tabindex="0">{{ n_label }}</li>
          </ul>
        </span>
      </h2>
    </div>

    {%- comment -%}── INTENTIONS PANEL ────────────────────────────────────{%- endcomment -%}
    <div class="narkk-dual-grid__panel" data-narkk-panel="intentions">
      <div class="narkk-dual-grid__content">

        <div class="narkk-dual-grid__row-featured narkk-dual-grid__row-featured--{{ i_feat_pos }}">
          {%- if i_use_blog -%}
            {%- for article in section.settings.intentions_blog.articles limit: 3 -%}
              {%- assign is_feat = forloop.first -%}
              <a
                href="{{ article.url }}"
                class="narkk-dual-grid__card{% if is_feat %} narkk-dual-grid__card--featured{% endif %}"
                data-narkk-dual-card
              >
                <div class="narkk-dual-grid__card-img-wrap">
                  {%- if article.image -%}
                    <img
                      src="{{ article.image | image_url: width: 1200 }}"
                      srcset="{{ article.image | image_url: width: 450 }} 450w, {{ article.image | image_url: width: 900 }} 900w, {{ article.image | image_url: width: 1200 }} 1200w"
                      sizes="(max-width: 749px) 50vw, {% if is_feat %}35vw{% else %}18vw{% endif %}"
                      alt="{{ article.image.alt | default: article.title | escape }}"
                      class="narkk-dual-grid__card-img"
                      loading="lazy"
                      width="{{ article.image.width }}"
                      height="{{ article.image.height }}"
                    >
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'narkk-dual-grid__card-placeholder' }}
                  {%- endif -%}
                </div>
                <div class="narkk-dual-grid__card-text">
                  {%- unless article.tags == empty -%}
                    <p class="narkk-dual-grid__card-eyebrow">{{ article.tags | first }}</p>
                  {%- endunless -%}
                  <p class="narkk-dual-grid__card-title">{{ article.title }}</p>
                </div>
              </a>
            {%- endfor -%}
          {%- else -%}
            {%- for block in i_blocks limit: 3 -%}
              {%- assign is_feat = forloop.first -%}
              <a
                href="{% if block.settings.url != blank %}{{ block.settings.url }}{% else %}#{% endif %}"
                class="narkk-dual-grid__card{% if is_feat %} narkk-dual-grid__card--featured{% endif %}{% if block.settings.url == blank %} narkk-dual-grid__card--no-link{% endif %}"
                data-narkk-dual-card
                {{ block.shopify_attributes }}
              >
                <div class="narkk-dual-grid__card-img-wrap">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 1200 }}"
                      srcset="{{ block.settings.image | image_url: width: 450 }} 450w, {{ block.settings.image | image_url: width: 900 }} 900w, {{ block.settings.image | image_url: width: 1200 }} 1200w"
                      sizes="(max-width: 749px) 50vw, {% if is_feat %}35vw{% else %}18vw{% endif %}"
                      alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                      class="narkk-dual-grid__card-img"
                      loading="lazy"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                    >
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'narkk-dual-grid__card-placeholder' }}
                  {%- endif -%}
                </div>
                <div class="narkk-dual-grid__card-text">
                  {%- if block.settings.eyebrow != blank -%}
                    <p class="narkk-dual-grid__card-eyebrow">{{ block.settings.eyebrow }}</p>
                  {%- endif -%}
                  {%- if block.settings.title != blank -%}
                    <p class="narkk-dual-grid__card-title">{{ block.settings.title }}</p>
                  {%- endif -%}
                </div>
              </a>
            {%- endfor -%}
            {%- if i_blocks.size < 3 -%}
              {%- assign i_fill = 3 | minus: i_blocks.size -%}
              {%- for f in (1..i_fill) -%}
                <div class="narkk-dual-grid__card narkk-dual-grid__card--placeholder" data-narkk-dual-card>
                  <div class="narkk-dual-grid__card-img-wrap">{{ 'image' | placeholder_svg_tag: 'narkk-dual-grid__card-placeholder' }}</div>
                  <div class="narkk-dual-grid__card-text">
                    <p class="narkk-dual-grid__card-eyebrow">Article</p>
                    <p class="narkk-dual-grid__card-title">Article preview coming soon</p>
                  </div>
                </div>
              {%- endfor -%}
            {%- endif -%}
          {%- endif -%}
        </div>

        <div class="narkk-dual-grid__row-more">
          {%- if i_use_blog -%}
            {%- for article in section.settings.intentions_blog.articles limit: 4 offset: 3 -%}
              <a href="{{ article.url }}" class="narkk-dual-grid__card" data-narkk-dual-card>
                <div class="narkk-dual-grid__card-img-wrap">
                  {%- if article.image -%}
                    <img
                      src="{{ article.image | image_url: width: 900 }}"
                      srcset="{{ article.image | image_url: width: 450 }} 450w, {{ article.image | image_url: width: 900 }} 900w"
                      sizes="(max-width: 749px) 50vw, 22vw"
                      alt="{{ article.image.alt | default: article.title | escape }}"
                      class="narkk-dual-grid__card-img"
                      loading="lazy"
                      width="{{ article.image.width }}"
                      height="{{ article.image.height }}"
                    >
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'narkk-dual-grid__card-placeholder' }}
                  {%- endif -%}
                </div>
                <div class="narkk-dual-grid__card-text">
                  {%- unless article.tags == empty -%}
                    <p class="narkk-dual-grid__card-eyebrow">{{ article.tags | first }}</p>
                  {%- endunless -%}
                  <p class="narkk-dual-grid__card-title">{{ article.title }}</p>
                </div>
              </a>
            {%- endfor -%}
          {%- else -%}
            {%- for block in i_blocks limit: 4 offset: 3 -%}
              <a
                href="{% if block.settings.url != blank %}{{ block.settings.url }}{% else %}#{% endif %}"
                class="narkk-dual-grid__card{% if block.settings.url == blank %} narkk-dual-grid__card--no-link{% endif %}"
                data-narkk-dual-card
                {{ block.shopify_attributes }}
              >
                <div class="narkk-dual-grid__card-img-wrap">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 900 }}"
                      srcset="{{ block.settings.image | image_url: width: 450 }} 450w, {{ block.settings.image | image_url: width: 900 }} 900w"
                      sizes="(max-width: 749px) 50vw, 22vw"
                      alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                      class="narkk-dual-grid__card-img"
                      loading="lazy"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                    >
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'narkk-dual-grid__card-placeholder' }}
                  {%- endif -%}
                </div>
                <div class="narkk-dual-grid__card-text">
                  {%- if block.settings.eyebrow != blank -%}
                    <p class="narkk-dual-grid__card-eyebrow">{{ block.settings.eyebrow }}</p>
                  {%- endif -%}
                  {%- if block.settings.title != blank -%}
                    <p class="narkk-dual-grid__card-title">{{ block.settings.title }}</p>
                  {%- endif -%}
                </div>
              </a>
            {%- endfor -%}
          {%- endif -%}
        </div>

      </div>
    </div>

    {%- comment -%}── NARKK PANEL ─────────────────────────────────────────{%- endcomment -%}
    <div class="narkk-dual-grid__panel narkk-dual-grid__panel--hidden" data-narkk-panel="narkk">
      <div class="narkk-dual-grid__content">

        <div class="narkk-dual-grid__row-featured narkk-dual-grid__row-featured--{{ n_feat_pos }}">
          {%- if n_use_blog -%}
            {%- for article in section.settings.narkk_blog.articles limit: 3 -%}
              {%- assign is_feat = forloop.first -%}
              <a
                href="{{ article.url }}"
                class="narkk-dual-grid__card{% if is_feat %} narkk-dual-grid__card--featured{% endif %}"
                data-narkk-dual-card
              >
                <div class="narkk-dual-grid__card-img-wrap">
                  {%- if article.image -%}
                    <img
                      src="{{ article.image | image_url: width: 1200 }}"
                      srcset="{{ article.image | image_url: width: 450 }} 450w, {{ article.image | image_url: width: 900 }} 900w, {{ article.image | image_url: width: 1200 }} 1200w"
                      sizes="(max-width: 749px) 50vw, {% if is_feat %}35vw{% else %}18vw{% endif %}"
                      alt="{{ article.image.alt | default: article.title | escape }}"
                      class="narkk-dual-grid__card-img"
                      loading="lazy"
                      width="{{ article.image.width }}"
                      height="{{ article.image.height }}"
                    >
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'narkk-dual-grid__card-placeholder' }}
                  {%- endif -%}
                </div>
                <div class="narkk-dual-grid__card-text">
                  {%- unless article.tags == empty -%}
                    <p class="narkk-dual-grid__card-eyebrow">{{ article.tags | first }}</p>
                  {%- endunless -%}
                  <p class="narkk-dual-grid__card-title">{{ article.title }}</p>
                </div>
              </a>
            {%- endfor -%}
          {%- else -%}
            {%- for block in n_blocks limit: 3 -%}
              {%- assign is_feat = forloop.first -%}
              <a
                href="{% if block.settings.url != blank %}{{ block.settings.url }}{% else %}#{% endif %}"
                class="narkk-dual-grid__card{% if is_feat %} narkk-dual-grid__card--featured{% endif %}{% if block.settings.url == blank %} narkk-dual-grid__card--no-link{% endif %}"
                data-narkk-dual-card
                {{ block.shopify_attributes }}
              >
                <div class="narkk-dual-grid__card-img-wrap">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 1200 }}"
                      srcset="{{ block.settings.image | image_url: width: 450 }} 450w, {{ block.settings.image | image_url: width: 900 }} 900w, {{ block.settings.image | image_url: width: 1200 }} 1200w"
                      sizes="(max-width: 749px) 50vw, {% if is_feat %}35vw{% else %}18vw{% endif %}"
                      alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                      class="narkk-dual-grid__card-img"
                      loading="lazy"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                    >
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'narkk-dual-grid__card-placeholder' }}
                  {%- endif -%}
                </div>
                <div class="narkk-dual-grid__card-text">
                  {%- if block.settings.eyebrow != blank -%}
                    <p class="narkk-dual-grid__card-eyebrow">{{ block.settings.eyebrow }}</p>
                  {%- endif -%}
                  {%- if block.settings.title != blank -%}
                    <p class="narkk-dual-grid__card-title">{{ block.settings.title }}</p>
                  {%- endif -%}
                </div>
              </a>
            {%- endfor -%}
            {%- if n_blocks.size < 3 -%}
              {%- assign n_fill = 3 | minus: n_blocks.size -%}
              {%- for f in (1..n_fill) -%}
                <div class="narkk-dual-grid__card narkk-dual-grid__card--placeholder" data-narkk-dual-card>
                  <div class="narkk-dual-grid__card-img-wrap">{{ 'image' | placeholder_svg_tag: 'narkk-dual-grid__card-placeholder' }}</div>
                  <div class="narkk-dual-grid__card-text">
                    <p class="narkk-dual-grid__card-eyebrow">Article</p>
                    <p class="narkk-dual-grid__card-title">Article preview coming soon</p>
                  </div>
                </div>
              {%- endfor -%}
            {%- endif -%}
          {%- endif -%}
        </div>

        <div class="narkk-dual-grid__row-more">
          {%- if n_use_blog -%}
            {%- for article in section.settings.narkk_blog.articles limit: 4 offset: 3 -%}
              <a href="{{ article.url }}" class="narkk-dual-grid__card" data-narkk-dual-card>
                <div class="narkk-dual-grid__card-img-wrap">
                  {%- if article.image -%}
                    <img
                      src="{{ article.image | image_url: width: 900 }}"
                      srcset="{{ article.image | image_url: width: 450 }} 450w, {{ article.image | image_url: width: 900 }} 900w"
                      sizes="(max-width: 749px) 50vw, 22vw"
                      alt="{{ article.image.alt | default: article.title | escape }}"
                      class="narkk-dual-grid__card-img"
                      loading="lazy"
                      width="{{ article.image.width }}"
                      height="{{ article.image.height }}"
                    >
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'narkk-dual-grid__card-placeholder' }}
                  {%- endif -%}
                </div>
                <div class="narkk-dual-grid__card-text">
                  {%- unless article.tags == empty -%}
                    <p class="narkk-dual-grid__card-eyebrow">{{ article.tags | first }}</p>
                  {%- endunless -%}
                  <p class="narkk-dual-grid__card-title">{{ article.title }}</p>
                </div>
              </a>
            {%- endfor -%}
          {%- else -%}
            {%- for block in n_blocks limit: 4 offset: 3 -%}
              <a
                href="{% if block.settings.url != blank %}{{ block.settings.url }}{% else %}#{% endif %}"
                class="narkk-dual-grid__card{% if block.settings.url == blank %} narkk-dual-grid__card--no-link{% endif %}"
                data-narkk-dual-card
                {{ block.shopify_attributes }}
              >
                <div class="narkk-dual-grid__card-img-wrap">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 900 }}"
                      srcset="{{ block.settings.image | image_url: width: 450 }} 450w, {{ block.settings.image | image_url: width: 900 }} 900w"
                      sizes="(max-width: 749px) 50vw, 22vw"
                      alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                      class="narkk-dual-grid__card-img"
                      loading="lazy"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                    >
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'narkk-dual-grid__card-placeholder' }}
                  {%- endif -%}
                </div>
                <div class="narkk-dual-grid__card-text">
                  {%- if block.settings.eyebrow != blank -%}
                    <p class="narkk-dual-grid__card-eyebrow">{{ block.settings.eyebrow }}</p>
                  {%- endif -%}
                  {%- if block.settings.title != blank -%}
                    <p class="narkk-dual-grid__card-title">{{ block.settings.title }}</p>
