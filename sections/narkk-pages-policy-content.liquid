{{ 'narkk-pages-policy-content.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} .narkk-policy-content {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<section class="narkk-policy-content" data-narkk-policy-content>
  <div class="narkk-policy-content__inner">

    {%- for block in section.blocks -%}

      {%- case block.type -%}

        {%- when 'section_heading' -%}
          {%- if block.settings.heading != blank -%}
            <h2 class="narkk-policy-content__section-heading" {{ block.shopify_attributes }}>
              {{- block.settings.heading -}}
            </h2>
          {%- endif -%}

        {%- when 'intro_text' -%}
          {%- if block.settings.content != blank -%}
            <div class="narkk-policy-content__intro" {{ block.shopify_attributes }}>
              {{- block.settings.content -}}
            </div>
          {%- endif -%}

        {%- when 'subsection' -%}
          <div class="narkk-policy-content__subsection" {{ block.shopify_attributes }}>

            {%- if block.settings.heading != blank -%}
              <h3 class="narkk-policy-content__sub-heading">
                {{- block.settings.heading -}}
              </h3>
            {%- endif -%}

            <div class="narkk-policy-content__divider" aria-hidden="true">&nbsp;</div>

            {%- if block.settings.content != blank -%}
              <div class="narkk-policy-content__body">
                {{- block.settings.content -}}
              </div>
            {%- endif -%}

          </div>

      {%- endcase -%}

    {%- endfor -%}

  </div>
</section>

{% schema %}
{
  "name": "Policy Content",
  "tag": "section",
  "class": "narkk-policy-content-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 8,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "section_heading",
      "name": "Section heading",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Section Title"
        }
      ]
    },
    {
      "type": "intro_text",
      "name": "Intro text",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Introductory paragraph text goes here.</p>"
        }
      ]
    },
    {
      "type": "subsection",
      "name": "Sub-section",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Sub-section heading",
          "default": "Sub-section Title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Sub-section content goes here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Policy Content",
      "blocks": [
        {
          "type": "section_heading",
          "settings": {
            "heading": "Order Processing"
          }
        },
        {
          "type": "intro_text",
          "settings": {
            "content": "<p>All orders are processed within 1-2 Business Days after payment confirmation. Business days are Monday to Saturday - 10:00AM to 07:00PM (IST), excluding public holidays.</p>"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "heading": "Order Shipping",
            "content": "<p>Most of our products are made to order, crafted individually with careful attention to detail.</p><ul><li>Once an order is placed, production begins and requires a minimum of 3 weeks to complete.</li><li>Shipping timelines will be shared after production is finished, based on your delivery location.</li><li>Since items are custom-made, cancellations or changes are not permitted once production has started.</li><li>You will receive regular updates on your order status, including tracking details once your product is dispatched.</li></ul>"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "heading": "Business Hours",
            "content": "<p>Our operational hours are Monday to Saturday, from 10:00AM to 07:00PM. Orders placed outside business hours or on holidays will be processed on the next working day.</p>"
          }
        },
        {
          "type": "subsection",
          "settings": {
            "heading": "Additional Information",
            "content": "<p>Once your order is shipped, you will receive a tracking number via email. Please allow up to 24 hours for the tracking information to update.</p><p>For any shipping-related queries, contact us at <a href=\"mailto:hello@naarkk.com\">hello@naarkk.com</a>.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
