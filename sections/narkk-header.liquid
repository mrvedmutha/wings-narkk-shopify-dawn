{{ 'narkk-header.css' | asset_url | stylesheet_tag }}

<header class="narkk-header" role="banner">

  {%- if section.settings.show_announcement -%}
    <div class="narkk-announcement">
      {%- if section.settings.announcement_link != blank -%}
        <a class="narkk-announcement__text" href="{{ section.settings.announcement_link }}">
          {{- section.settings.announcement_text -}}
        </a>
      {%- else -%}
        <span class="narkk-announcement__text">{{- section.settings.announcement_text -}}</span>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="narkk-nav-wrapper">
    <div class="narkk-nav-container">

      {%- comment -%} Desktop left nav — Shopify menu linklist {%- endcomment -%}
      <nav class="narkk-nav-left" aria-label="Main navigation">
        {%- for link in linklists[section.settings.menu].links -%}
          {%- if forloop.index > 1 -%}
            <div class="narkk-divider" aria-hidden="true"></div>
          {%- endif -%}
          <a
            class="narkk-nav-item{% if forloop.index == 3 %} narkk-nav-item--wide{% endif %}"
            href="{{ link.url }}"
            {% if link.current %}aria-current="page"{% endif %}
          >
            <span class="narkk-nav-label">{{ link.title | upcase }}</span>
            <span class="narkk-nav-fill" aria-hidden="true">{{ link.title | upcase }}</span>
          </a>
        {%- endfor -%}
        {%- if linklists[section.settings.menu].links.size > 0 -%}
          <div class="narkk-divider" aria-hidden="true"></div>
        {%- endif -%}
      </nav>

      {%- comment -%} Mobile: hamburger sits in the left flex zone {%- endcomment -%}
      <div class="narkk-mobile-left">
        <button
          class="narkk-hamburger"
          id="narkk-hamburger-btn"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="narkk-drawer"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      {%- comment -%} Centre logo — always visible {%- endcomment -%}
      <a class="narkk-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        <img
          src="{{ 'narkk-logo-black-new.svg' | asset_url }}"
          alt="{{ shop.name }}"
          loading="eager"
          fetchpriority="high"
        >
      </a>

      {%- comment -%} Right nav {%- endcomment -%}
      <div class="narkk-nav-right">

        {%- comment -%} Contact — hidden ≤768px via CSS {%- endcomment -%}
        <div class="narkk-divider narkk-divider--contact" aria-hidden="true"></div>
        <a
          class="narkk-nav-item narkk-nav-item--contact"
          href="{{ section.settings.contact_url }}"
        >
          <span class="narkk-nav-label">{{ section.settings.contact_text | default: 'Contact' | upcase }}</span>
          <span class="narkk-nav-fill" aria-hidden="true">{{ section.settings.contact_text | default: 'Contact' | upcase }}</span>
        </a>

        {%- comment -%} Account — hidden ≤425px via CSS {%- endcomment -%}
        <div class="narkk-divider narkk-divider--account" aria-hidden="true"></div>
        <a
          class="narkk-nav-item narkk-nav-item--icon narkk-nav-item--account"
          href="{{ routes.account_url }}"
          aria-label="{{ 'customer.account.title' | t }}"
        >
          <span class="narkk-nav-label">
            <img src="{{ 'icon-narkk-user.svg' | asset_url }}" alt="" width="15" height="19" aria-hidden="true">
          </span>
          <span class="narkk-nav-fill" aria-hidden="true">
            <img src="{{ 'icon-narkk-user.svg' | asset_url }}" alt="" width="15" height="19" aria-hidden="true">
          </span>
        </a>

        {%- comment -%} Cart — always visible {%- endcomment -%}
        <div class="narkk-divider" aria-hidden="true"></div>
        <a
          class="narkk-nav-item narkk-nav-item--icon"
          href="{{ routes.cart_url }}"
          aria-label="Cart ({{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }})"
        >
          <span class="narkk-nav-label">
            <img src="{{ 'icon-narkk-cart-bag.svg' | asset_url }}" alt="" width="15" height="17" aria-hidden="true">
            <span class="narkk-cart-count" data-cart-count>{{ cart.item_count }}</span>
          </span>
          <span class="narkk-nav-fill" aria-hidden="true">
            <img src="{{ 'icon-narkk-cart-bag.svg' | asset_url }}" alt="" width="15" height="17" aria-hidden="true">
            <span class="narkk-cart-count" data-cart-count aria-hidden="true">{{ cart.item_count }}</span>
          </span>
        </a>

      </div>
    </div>
  </div>

  {%- comment -%} Mobile side drawer {%- endcomment -%}
  <div class="narkk-drawer" id="narkk-drawer" aria-hidden="true" role="dialog" aria-label="Navigation menu">
    <div class="narkk-drawer-top">
      <a class="narkk-drawer-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        <img src="{{ 'narkk-logo-black-new.svg' | asset_url }}" alt="{{ shop.name }}">
      </a>
      <button class="narkk-drawer-close" id="narkk-drawer-close" aria-label="Close menu">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M1 1L17 17M17 1L1 17" stroke="currentColor" stroke-width="1"/>
        </svg>
      </button>
    </div>
    <nav class="narkk-drawer-nav" aria-label="Mobile navigation">
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}" {% if link.current %}aria-current="page"{% endif %}>
          {{- link.title | upcase -}}
        </a>
      {%- endfor -%}
      {%- if section.settings.contact_url != blank -%}
        <a href="{{ section.settings.contact_url }}">
          {{- section.settings.contact_text | default: 'Contact' | upcase -}}
        </a>
      {%- endif -%}
    </nav>
  </div>
  <div class="narkk-overlay" id="narkk-overlay" aria-hidden="true"></div>

</header>

<script src="{{ 'gsap.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'narkk-header.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Narkk Header",
  "tag": "section",
  "class": "narkk-header-section",
  "settings": [
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "New Arrivals  I  Discover the latest Pieces"
    },
    {
      "type": "url",
      "id": "announcement_link",
      "label": "Announcement link (optional)"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Left navigation menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact label",
      "default": "Contact"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Contact page URL"
    }
  ],
  "presets": [
    {
      "name": "Narkk Header"
    }
  ]
}
{% endschema %}
