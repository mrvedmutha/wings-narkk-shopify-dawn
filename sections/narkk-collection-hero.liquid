{{ 'narkk-plp-hero.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} .narkk-plp-hero {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

{%- assign hero_image = collection.metafields.custom.hero_image.value -%}
{%- if hero_image == blank -%}
  {%- assign hero_image = collection.image -%}
{%- endif -%}
{%- assign hero_tagline = collection.metafields.custom.hero_tagline -%}

<section class="narkk-plp-hero" data-narkk-plp-hero>
  <div class="narkk-plp-hero__inner">

    {%- comment -%}── BREADCRUMB ────────────────────────────────────────────{%- endcomment -%}
    <nav class="narkk-plp-hero__breadcrumb" aria-label="Breadcrumb" data-narkk-plp-breadcrumb>
      <a href="{{ routes.root_url }}" class="narkk-plp-hero__breadcrumb-item">home</a>
      <span class="narkk-plp-hero__breadcrumb-sep" aria-hidden="true">&rsaquo;</span>
      <span class="narkk-plp-hero__breadcrumb-item">products</span>
      <span class="narkk-plp-hero__breadcrumb-sep" aria-hidden="true">&rsaquo;</span>
      <span class="narkk-plp-hero__breadcrumb-item">{{ collection.title | downcase }}</span>
    </nav>

    {%- comment -%}── CONTENT ROW ───────────────────────────────────────────{%- endcomment -%}
    <div class="narkk-plp-hero__content">

      <div class="narkk-plp-hero__image-wrap">
        {%- if hero_image != blank -%}
          <img
            src="{{ hero_image | image_url: width: 1200 }}"
            srcset="
              {{ hero_image | image_url: width: 600 }} 600w,
              {{ hero_image | image_url: width: 900 }} 900w,
              {{ hero_image | image_url: width: 1200 }} 1200w
            "
            sizes="(max-width: 1024px) 100vw, 59vw"
            alt="{{ collection.title | escape }}"
            loading="eager"
            width="{{ hero_image.width }}"
            height="{{ hero_image.height }}"
            class="narkk-plp-hero__image"
            data-narkk-plp-image
          >
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'narkk-plp-hero__image narkk-plp-hero__image--placeholder' }}
        {%- endif -%}
      </div>

      <div class="narkk-plp-hero__side">
        <h1 class="narkk-plp-hero__heading" data-narkk-plp-heading style="visibility:hidden">
          {{- collection.title -}}
        </h1>
        {%- if collection.description != blank -%}
          <div class="narkk-plp-hero__description" data-narkk-plp-description style="visibility:hidden">
            {{ collection.description }}
          </div>
        {%- endif -%}
        {%- if hero_tagline != blank -%}
          <p class="narkk-plp-hero__tagline" data-narkk-plp-tagline style="visibility:hidden">
            {{ hero_tagline }}
          </p>
        {%- endif -%}
      </div>

    </div>

  </div>
</section>

<script src="{{ 'gsap.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'narkk-text-reveal.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'narkk-plp-hero.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Collection Hero",
  "tag": "section",
  "class": "narkk-plp-hero-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Pulls from the collection: title, description (native fields). Image uses metafield custom.hero_image if set, otherwise falls back to the collection's own Image field. Tagline uses metafield custom.hero_tagline."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 160
    }
  ],
  "presets": [
    {
      "name": "Collection Hero"
    }
  ]
}
{% endschema %}
