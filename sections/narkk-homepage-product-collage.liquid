{{ 'narkk-homepage-product-collage.css' | asset_url | stylesheet_tag }}

<section class="narkk-collage" data-narkk-collage>

  {%- comment -%}── DIVIDER LINES (desktop only) ─────────────────────────{%- endcomment -%}
  <div class="narkk-collage__h-line" aria-hidden="true">&nbsp;</div>
  <div class="narkk-collage__v-line" aria-hidden="true">&nbsp;</div>

  {%- comment -%}── LEFT: Image collage ──────────────────────────────────{%- endcomment -%}
  <div class="narkk-collage__images">

    <div class="narkk-collage__img-wrap narkk-collage__img-wrap--1">
      {%- if section.settings.image_1 != blank -%}
        <img
          src="{{ section.settings.image_1 | image_url: width: 600 }}"
          alt="{{ section.settings.image_1.alt | escape }}"
          class="narkk-collage__img"
          loading="lazy"
          width="{{ section.settings.image_1.width }}"
          height="{{ section.settings.image_1.height }}"
        >
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'narkk-collage__img narkk-collage__img--placeholder' }}
      {%- endif -%}
    </div>

    <div class="narkk-collage__img-wrap narkk-collage__img-wrap--2">
      {%- if section.settings.image_2 != blank -%}
        <img
          src="{{ section.settings.image_2 | image_url: width: 800 }}"
          alt="{{ section.settings.image_2.alt | escape }}"
          class="narkk-collage__img"
          loading="lazy"
          width="{{ section.settings.image_2.width }}"
          height="{{ section.settings.image_2.height }}"
        >
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'narkk-collage__img narkk-collage__img--placeholder' }}
      {%- endif -%}
    </div>

  </div>

  {%- comment -%}── RIGHT: Text content ──────────────────────────────────{%- endcomment -%}
  <div class="narkk-collage__text">

    {%- if section.settings.eyebrow != blank -%}
      <p class="narkk-collage__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    <div class="narkk-collage__body-group">
      {%- if section.settings.heading != blank -%}
        <p class="narkk-collage__heading">{{ section.settings.heading }}</p>
      {%- endif -%}
      {%- render 'narkk-button',
        label: section.settings.cta_label,
        url: section.settings.cta_url,
        style: 'outlined',
        show_plus: true
      -%}
    </div>

  </div>

</section>

<script src="{{ 'gsap.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'narkk-text-reveal.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'narkk-homepage-product-collage.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Narkk Product Collage",
  "tag": "section",
  "class": "narkk-collage-section",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1 — top (portrait, smaller)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 — bottom (portrait, larger)"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "About Narkk"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Based in Chennai — India, we design modular products that evolves as you evolve with it."
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "About Narkk"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Narkk Product Collage"
    }
  ]
}
{% endschema %}
