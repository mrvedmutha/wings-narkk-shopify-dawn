{{ 'narkk-pages-text-rich.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} .narkk-text-rich {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<section class="narkk-text-rich" data-narkk-text-rich>
  <div class="narkk-text-rich__inner">

    {%- if section.settings.heading != blank -%}
      <h2
        class="narkk-text-rich__heading{% if section.settings.uppercase %} narkk-text-rich__heading--upper{% endif %}"
        data-text-rich-heading
      >{{ section.settings.heading }}</h2>
    {%- endif -%}

  </div>
</section>

<script src="{{ 'gsap.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'narkk-text-reveal.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'narkk-pages-text-rich.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Text Rich",
  "tag": "section",
  "class": "narkk-text-rich-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Buy once, mend often, keep forever"
    },
    {
      "type": "checkbox",
      "id": "uppercase",
      "label": "Uppercase text",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Text Rich"
    }
  ]
}
{% endschema %}
