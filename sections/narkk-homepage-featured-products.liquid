{{ 'narkk-homepage-featured-products.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign coll  = section.settings.collection
  assign prods = coll.products
-%}

<section class="narkk-fp" data-narkk-fp>
  <div class="narkk-fp__inner">

    {%- comment -%}── HEADING ─────────────────────────────────────────────{%- endcomment -%}
    <div class="narkk-fp__heading-wrap">
      <h2
        class="narkk-fp__heading"
        data-narkk-split
        data-narkk-split-stagger="0.03"
        style="visibility:hidden"
      >
        {{- section.settings.heading | default: 'Featured Products' -}}
      </h2>
    </div>

    {%- comment -%}── PRODUCT GRID ─────────────────────────────────────────{%- endcomment -%}
    <div class="narkk-fp__grid">

      {%- comment -%}── ROW 1: 1 large (left) + 2 small (right) ────────────{%- endcomment -%}
      <div class="narkk-fp__row narkk-fp__row--1">

        <div class="narkk-fp__slot narkk-fp__slot--large">
          {%- render 'narkk-product-card',
            product:          prods[0],
            size:             'large',
            index:            0,
            mock_image:       section.settings.slot_1_image,
            mock_image_hover: section.settings.slot_1_image_hover,
            mock_vendor:      section.settings.slot_1_vendor,
            mock_title:       section.settings.slot_1_title,
            mock_price:       section.settings.slot_1_price
          -%}
        </div>

        <div class="narkk-fp__slot narkk-fp__slot--small-pair">
          {%- render 'narkk-product-card',
            product:          prods[1],
            size:             'small',
            index:            1,
            mock_image:       section.settings.slot_2_image,
            mock_image_hover: section.settings.slot_2_image_hover,
            mock_vendor:      section.settings.slot_2_vendor,
            mock_title:       section.settings.slot_2_title,
            mock_price:       section.settings.slot_2_price
          -%}
          {%- render 'narkk-product-card',
            product:          prods[2],
            size:             'small',
            index:            2,
            mock_image:       section.settings.slot_3_image,
            mock_image_hover: section.settings.slot_3_image_hover,
            mock_vendor:      section.settings.slot_3_vendor,
            mock_title:       section.settings.slot_3_title,
            mock_price:       section.settings.slot_3_price
          -%}
        </div>

      </div>

      {%- comment -%}── ROW 2: 2 small (left) + 1 large (right) ────────────{%- endcomment -%}
      <div class="narkk-fp__row narkk-fp__row--2">

        <div class="narkk-fp__slot narkk-fp__slot--small-pair">
          {%- render 'narkk-product-card',
            product:          prods[3],
            size:             'small',
            index:            3,
            mock_image:       section.settings.slot_4_image,
            mock_image_hover: section.settings.slot_4_image_hover,
            mock_vendor:      section.settings.slot_4_vendor,
            mock_title:       section.settings.slot_4_title,
            mock_price:       section.settings.slot_4_price
          -%}
          {%- render 'narkk-product-card',
            product:          prods[4],
            size:             'small',
            index:            4,
            mock_image:       section.settings.slot_5_image,
            mock_image_hover: section.settings.slot_5_image_hover,
            mock_vendor:      section.settings.slot_5_vendor,
            mock_title:       section.settings.slot_5_title,
            mock_price:       section.settings.slot_5_price
          -%}
        </div>

        <div class="narkk-fp__slot narkk-fp__slot--large">
          {%- render 'narkk-product-card',
            product:          prods[5],
            size:             'large',
            index:            5,
            mock_image:       section.settings.slot_6_image,
            mock_image_hover: section.settings.slot_6_image_hover,
            mock_vendor:      section.settings.slot_6_vendor,
            mock_title:       section.settings.slot_6_title,
            mock_price:       section.settings.slot_6_price
          -%}
        </div>

      </div>

    </div>

  </div>
</section>

<script src="{{ 'gsap.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'narkk-text-reveal.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'narkk-homepage-featured-products.js' | asset_url }}" defer="defer"></script>

