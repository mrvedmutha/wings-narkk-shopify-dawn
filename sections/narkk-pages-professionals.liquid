{{ 'narkk-pages-professionals.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} .narkk-professionals {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<section class="narkk-professionals" data-narkk-professionals>

  {%- comment -%}── Eyebrow ──────────────────────────────────────────────{%- endcomment -%}
  <div class="narkk-professionals__inner">
    {%- if section.settings.heading != blank -%}
      <p class="narkk-professionals__eyebrow" data-prof-eyebrow>
        {{ section.settings.heading }}
      </p>
    {%- endif -%}
  </div>

  {%- assign industry_blocks = section.blocks | where: 'type', 'industry' -%}

  {%- comment -%}── Image zone: line sits at vertical centre of image ────{%- endcomment -%}
  <div class="narkk-professionals__image-zone">
    <div class="narkk-professionals__line" data-prof-line>&nbsp;</div>
    <div class="narkk-professionals__inner">
      <div class="narkk-professionals__image-wrap" data-prof-image>
        {%- if industry_blocks.size > 0 -%}
          {%- for block in industry_blocks -%}
            <div
              class="narkk-professionals__image-slide{% if forloop.first %} is-active{% endif %}"
              data-prof-image-slide
              data-industry-index="{{ forloop.index0 }}"
            >
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  srcset="
                    {{ block.settings.image | image_url: width: 300 }} 300w,
                    {{ block.settings.image | image_url: width: 600 }} 600w
                  "
                  sizes="(max-width: 768px) 72vw, 275px"
                  alt="{{ block.settings.image.alt | default: block.settings.label | escape }}"
                  class="narkk-professionals__image"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              {%- else -%}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'narkk-professionals__image narkk-professionals__image-placeholder' }}
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'narkk-professionals__image narkk-professionals__image-placeholder' }}
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%}── Industries — one flowing, comma-separated line that wraps naturally ──{%- endcomment -%}
  {%- if industry_blocks.size > 0 -%}
    <div class="narkk-professionals__inner">
      <div class="narkk-professionals__text" data-prof-text>
        <p class="narkk-professionals__flow">
          {%- for block in industry_blocks -%}
            {%- if block.settings.label != blank -%}
              <span
                class="narkk-professionals__industry{% if forloop.first %} is-active{% endif %}"
                data-prof-industry
                data-industry-index="{{ forloop.index0 }}"
                role="button"
                tabindex="0"
                {{ block.shopify_attributes }}
              >{{- block.settings.label -}}</span>{%- unless forloop.last -%}<span class="narkk-professionals__comma">, </span>{%- endunless -%}
            {%- endif -%}
          {%- endfor -%}
        </p>
      </div>
    </div>
  {%- endif -%}

</section>

<script src="{{ 'gsap.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'narkk-text-reveal.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'narkk-pages-professionals.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Professionals",
  "tag": "section",
  "class": "narkk-professionals-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Eyebrow heading",
      "default": "Who This Is For"
    },
    {
      "type": "paragraph",
      "content": "Add an Industry block per audience below — they flow as one comma-separated line that wraps naturally. Hovering (or tapping, on touch) an industry highlights it and swaps in its image."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 8,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 8,
      "unit": "px",
      "default": 120
    }
  ],
  "blocks": [
    {
      "type": "industry",
      "name": "Industry",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Industry name",
          "info": "e.g. Interior Designers"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Shown above when this industry is hovered/tapped"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Professionals",
      "blocks": [
        { "type": "industry", "settings": { "label": "Interior Designers" } },
        { "type": "industry", "settings": { "label": "Architects" } },
        { "type": "industry", "settings": { "label": "Home Stagers" } },
        { "type": "industry", "settings": { "label": "Hospitality Consultants" } },
        { "type": "industry", "settings": { "label": "Set Designers" } },
        { "type": "industry", "settings": { "label": "Design Studios" } }
      ]
    }
  ]
}
{% endschema %}
