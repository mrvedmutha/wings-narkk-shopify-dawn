{%- comment -%}
  Renders a Ready Setup (bundle) card for the collection slider.
  Variables:
    product {Product} — required
{%- endcomment -%}

{%- assign board_type = product.metafields.custom.board_type -%}
{%- assign acc_count  = product.metafields.custom.accessories_count -%}
{%- assign first_variant = product.selected_or_first_available_variant -%}
{%- assign has_one_variant = false -%}
{%- if product.variants.size == 1 -%}
  {%- assign has_one_variant = true -%}
{%- endif -%}

<article class="narkk-plp-bundle-card">

  <div class="narkk-plp-bundle-card__image-wrap">
    <a href="{{ product.url }}" class="narkk-plp-bundle-card__image-link" aria-hidden="true" tabindex="-1">
      {%- if product.featured_image != blank -%}
        <img
          src="{{ product.featured_image | image_url: width: 1400 }}"
          srcset="
            {{ product.featured_image | image_url: width: 700 }} 700w,
            {{ product.featured_image | image_url: width: 1000 }} 1000w,
            {{ product.featured_image | image_url: width: 1400 }} 1400w
          "
          sizes="(max-width: 1024px) 100vw, 50vw"
          alt="{{ product.title | escape }}"
          loading="lazy"
          class="narkk-plp-bundle-card__image"
          width="{{ product.featured_image.width }}"
          height="{{ product.featured_image.height }}"
        >
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'narkk-plp-bundle-card__image narkk-plp-bundle-card__image--placeholder' }}
      {%- endif -%}
    </a>

    <div class="narkk-plp-bundle-card__atc-wrap">
      {%- if has_one_variant -%}
        <button
          type="button"
          class="button narkk-btn-primary narkk-btn--plus narkk-plp-bundle-card__atc"
          data-atc-btn
          data-variant-id="{{ first_variant.id }}"
          aria-label="Add {{ product.title | escape }} to cart"
        >
          <span class="narkk-btn__plus">+</span>
          <span class="narkk-btn__label">Add To Cart</span>
        </button>
      {%- else -%}
        <a
          href="{{ product.url }}"
          class="button narkk-btn-primary narkk-btn--plus narkk-plp-bundle-card__atc"
          aria-label="Choose options for {{ product.title | escape }}"
        >
          <span class="narkk-btn__plus">+</span>
          <span class="narkk-btn__label">Choose Options</span>
        </a>
      {%- endif -%}
    </div>
  </div>

  <a href="{{ product.url }}" class="narkk-plp-bundle-card__link">
    <div class="narkk-plp-bundle-card__info">
      <div class="narkk-plp-bundle-card__meta">
        <h3 class="narkk-plp-bundle-card__name">{{ product.title }}<span class="narkk-plp-bundle-card__name-line" aria-hidden="true">&nbsp;</span></h3>
        {%- if board_type != blank or acc_count != blank -%}
          <div class="narkk-plp-bundle-card__sub">
            {%- if board_type != blank -%}
              <span class="narkk-plp-bundle-card__board">{{ board_type }}</span>
            {%- endif -%}
            {%- if board_type != blank and acc_count != blank -%}
              <span class="narkk-plp-bundle-card__dot" aria-hidden="true"></span>
            {%- endif -%}
            {%- if acc_count != blank -%}
              <span class="narkk-plp-bundle-card__count">{{ acc_count }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
      <p class="narkk-plp-bundle-card__price">{{ product.price | money }}</p>
    </div>
  </a>

</article>
