        "cat_returns_P7q8R9": {
          "type": "faq-category",
          "name": "FAQ Category",
          "settings": {
            "label": "Returns & Support"
          },
          "blocks": {
            "item_b6_q1": {
              "type": "faq-item",
              "name": "FAQ Item",
              "settings": {
                "question": "What is your returns policy?",
                "answer": "<p>We accept returns on standard, unmodified products within 14 days of delivery, provided they are in original condition and packaging. Custom and made-to-order pieces are non-returnable unless faulty. To initiate a return, contact us with your order number and we'll guide you through the process.</p>"
              },
              "blocks": {}
            },
            "item_b6_q2": {
              "type": "faq-item",
              "name": "FAQ Item",
              "settings": {
                "question": "My order arrived damaged — what do I do?",
                "answer": "<p>Contact us within 48 hours of delivery with photos of the damage and your order number. We'll assess and arrange a replacement, repair, or refund depending on the extent of the issue. We take transit damage seriously and use it to improve our packaging.</p>"
              },
              "blocks": {}
            },
            "item_b6_q3": {
              "type": "faq-item",
              "name": "FAQ Item",
              "settings": {
                "question": "Who covers return shipping costs?",
                "answer": "<p>If the return is due to a fault or error on our part, we cover the return shipping cost in full. For change-of-mind returns, the customer is responsible for return shipping. We recommend using a tracked service, as we can't be liable for items lost in transit.</p>"
              },
              "blocks": {}
            },
            "item_b6_q4": {
              "type": "faq-item",
              "name": "FAQ Item",
              "settings": {
                "question": "How long does a refund take?",
                "answer": "<p>Once we receive and inspect the returned item, refunds are processed within 5 working days. The time it takes to appear in your account depends on your bank or card provider — typically 3–5 additional business days.</p>"
              },
              "blocks": {}
            },
            "item_b6_q5": {
              "type": "faq-item",
              "name": "FAQ Item",
              "settings": {
                "question": "Can I exchange a product instead of returning it?",
                "answer": "<p>Yes, exchanges are available for standard products within the 14-day return window. If you'd like a different size, finish, or product, contact us and we'll confirm availability. Any price difference will be charged or refunded accordingly.</p>"
              },
              "blocks": {}
            }
          },
