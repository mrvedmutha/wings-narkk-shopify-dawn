    "narkk_pages_trade_faq_K4M9jP": {
      "type": "narkk-pages-trade-faq",
      "blocks": {
        "faq_7rhEPx": {
          "type": "faq",
          "settings": {
            "question": "Is there a minimum order quantity to qualify for trade pricing?",
            "answer": "No minimum order quantity is required to access trade pricing. You can order as little or as much as you need for each project."
          }
        },
        "faq_9FUXBc": {
          "type": "faq",
          "settings": {
            "question": "How do I get to 20% discount?",
            "answer": "After three confirmed project orders through your trade account, your discount upgrades to 20% permanently — no application needed. We'll update your account automatically."
          }
        },
        "faq_7HnFqX": {
          "type": "faq",
          "settings": {
            "question": "Can I request custom colours or finishes for a project?",
            "answer": "Yes, custom colour and finish requests are available for qualifying projects. Reach out to your trade account manager to discuss options and lead times."
          }
        },
        "faq_W4yhEf": {
          "type": "faq",
          "settings": {
            "question": "Can I view or touch the products before specifying?",
            "answer": "Yes, we have a showroom available for trade clients. Contact us to arrange a visit or request a sample pack for your studio."
          }
        },
        "faq_PdDUwA": {
          "type": "faq",
          "settings": {
            "question": "What are typical lead times for trade orders?",
            "answer": "Standard lead times are 8–12 weeks depending on the product and current production schedule. Rush options may be available for select items."
          }
        },
        "faq_D4hDJd": {
          "type": "faq",
          "settings": {
            "question": "Can I mark up narkk products when billing my client?",
            "answer": "Yes, you're free to apply your own margin when billing your clients. Your trade pricing is confidential between you and narkk."
          }
        },
        "faq_7iengR": {
          "type": "faq",
          "settings": {
            "question": "Will narkk feature my project if I use your products?",
            "answer": "We love to share well-specified projects. If you'd like your project considered for our journal or social channels, send us the details and we'll review it."
          }
        }
      },
