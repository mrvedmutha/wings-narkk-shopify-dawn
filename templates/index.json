    "narkk_homepage_manifesto_9E4hby": {
      "type": "narkk-homepage-manifesto",
      "name": "Narkk Manifesto",
      "settings": {
        "eyebrow": "The Re-Manifesto",
        "heading": "Built for Life, Not the Landfill",
        "body": "<p>We stand as a direct counter-narrative to “fast furniture” and planned obsolescence. We believe that what you buy, how you live with it, and what you become of it are all interconnected. Our ultimate goal is to build a circular economy where no piece of Narkk furniture ever enters a landfill.</p><p>To ensure our products remain lifelong companions, we design, we operate by these 6 core principles</p>"
      }
    },
