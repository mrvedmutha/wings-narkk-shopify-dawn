{
  "env": {
    "browser": true,
    "es2020": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "script"
  },
  "globals": {
    "gsap": "readonly",
    "Lenis": "readonly",
    "ScrollTrigger": "readonly",
    "Shopify": "readonly",
    "subscribe": "readonly",
    "PUB_SUB_EVENTS": "readonly",
    "publish": "readonly"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "no-console": "warn",
    "eqeqeq": "error"
  },
  "ignorePatterns": [
    "node_modules/",
    "assets/vendor-*.js"
  ]
}
