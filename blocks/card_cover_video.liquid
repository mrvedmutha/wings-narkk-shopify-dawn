{% doc %}
Cover video card — full-bleed video, auto-plays muted and looped.
{% enddoc %}

<div class="narkk-bundle__card narkk-bundle__card--cover" {{ block.shopify_attributes }}>
  {%- if block.settings.video_url != blank -%}
    <video
      class="narkk-bundle__cover-media"
      autoplay
      loop
      muted
      playsinline
      data-lazy-src="{{ block.settings.video_url | escape }}"
    ></video>
  {%- else -%}
    {{ 'image' | placeholder_svg_tag: 'narkk-bundle__cover-media narkk-bundle__cover-media--placeholder' }}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Card — Cover Video",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "info": "Paste your Shopify CDN link (MP4). Video loads only when this tab is opened."
    }
  ],
  "presets": [
    { "name": "Card — Cover Video" }
  ]
}
{% endschema %}
