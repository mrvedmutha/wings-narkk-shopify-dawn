{% doc %}
Cover video card — full-bleed video, auto-plays muted and looped.
{% enddoc %}

<div class="narkk-bundle__card narkk-bundle__card--cover" {{ block.shopify_attributes }}>
  {%- if block.settings.video != blank -%}
    <div class="narkk-bundle__cover-media-wrap">
      {{- block.settings.video | video_tag:
        autoplay: true,
        loop: true,
        muted: true,
        playsinline: true
      -}}
    </div>
  {%- else -%}
    {{ 'image' | placeholder_svg_tag: 'narkk-bundle__cover-media narkk-bundle__cover-media--placeholder' }}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Card — Cover Video",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Cover video",
      "info": "Auto-plays muted and looped"
    }
  ],
  "presets": [
    { "name": "Card — Cover Video" }
  ]
}
{% endschema %}
