{% doc %}
Image card — product image contained on a beige background.
{% enddoc %}

<div class="narkk-bundle__card narkk-bundle__card--image" {{ block.shopify_attributes }}>
  {%- if block.settings.image != blank -%}
    <img
      src="{{ block.settings.image | image_url: width: 800 }}"
      alt="{{ block.settings.image.alt | escape }}"
      loading="lazy"
      width="{{ block.settings.image.width }}"
      height="{{ block.settings.image.height }}"
      class="narkk-bundle__card-img"
    >
  {%- else -%}
    {{ 'product-1' | placeholder_svg_tag: 'narkk-bundle__card-img narkk-bundle__card-img--placeholder' }}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Card — Image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    }
  ],
  "presets": [
    { "name": "Card — Image" }
  ]
}
{% endschema %}
